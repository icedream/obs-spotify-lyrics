{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "packageRules": [
    {
      "matchFileNames": ["go.mod", "go.sum"],
      "groupName": "goDeps"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update OBS_VERSION in workflow files and Makefile",
      "managerFilePatterns": ["/^\\.github/workflows/.+\\.ya?ml$/", "/^Makefile$/"],
      "matchStrings": ["OBS_VERSION:\\s+\"(?<currentValue>[\\d.]+)\"", "OBS_VERSION \\?=\\s+(?<currentValue>[\\d.]+)"],
      "datasourceTemplate": "github-releases",
      "depNameTemplate": "obsproject/obs-studio",
      "extractVersionTemplate": "^(?<version>.+)$"
    }
  ],
  "prConcurrentLimit": 10,
  "prHourlyLimit": 2
}
